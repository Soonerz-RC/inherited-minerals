# ---------------------------------------------------------------------------
# Example environment variables. Copy to .env for local dev, and add the same
# keys in Netlify (Site settings → Environment variables) for production.
#
# Everything is optional. With no values set, tracking stays inert and form
# storage falls back to in-memory. Nothing here ships with real secrets.
# ---------------------------------------------------------------------------

# --- Client-side tracking (VITE_* are inlined at build time) ----------------
# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
VITE_GA4_MEASUREMENT_ID=
# Google Ads conversion account ID (AW-XXXXXXXXXX)
VITE_GOOGLE_ADS_ID=
# Google Ads conversion labels (the part after the slash in send_to)
VITE_GOOGLE_ADS_REVIEW_CONVERSION_LABEL=
VITE_GOOGLE_ADS_QUESTION_CONVERSION_LABEL=
# Meta (Facebook) Pixel ID
VITE_META_PIXEL_ID=
# Google Search Console verification token (the content of the meta tag)
VITE_GOOGLE_SITE_VERIFICATION=

# --- Phone / call tracking (VITE_*) -----------------------------------------
# Public business phone number shown in CTAs. Defaults to the live Bland.ai
# intake line (405) 450-8680 when unset; set this to override (e.g. a different
# market or a temporary number).
VITE_PUBLIC_PHONE_NUMBER=
# Optional call-tracking DID; when set, it is displayed/dialed instead
VITE_CALL_TRACKING_NUMBER=

# --- Lead capture backend (VITE_*) ------------------------------------------
# Where form submissions go. Leave unset (or "netlify-forms") to capture leads
# with Netlify Forms — the current default durable storage, viewable in the
# Netlify dashboard. Set to "api" later to POST to the Netlify Functions
# (Supabase/Neon) path instead.
#   netlify-forms (default) | api
VITE_LEAD_BACKEND=

# --- Server-side: durable storage, OPTIONAL / future (Netlify Functions) ----
# Only used when VITE_LEAD_BACKEND=api. Supabase project URL and SERVICE ROLE
# key (server-only — never expose client-side). Leave blank while on Netlify Forms.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Server-side: Slack lead notifications (Netlify Functions) --------------
# Slack Incoming Webhook URL. When set, the form-to-slack function posts a
# formatted lead alert to Slack on each Netlify Form submission. Server-only —
# never exposed to the client. Wire it up via Site → Forms → Form notifications
# → Outgoing webhook → /.netlify/functions/form-to-slack
SLACK_WEBHOOK_URL=

# --- Server-side: Airtable durable lead backup (Netlify Functions) ----------
# When AIRTABLE_PAT (or AIRTABLE_API_KEY) is set, form-to-slack also writes each
# successfully-Slacked lead to the Airtable "Leads" table. This is best-effort:
# if the token is missing or the write fails, the Slack/lead flow still succeeds
# (the failure is logged server-side). Server-only — never exposed to client.
# Create a Personal Access Token at https://airtable.com/create/tokens with
# data.records:write scope on the base below.
AIRTABLE_PAT=
# Alternative name for the same token (either works; AIRTABLE_PAT wins):
# AIRTABLE_API_KEY=
# Base/table default to the production Leads table when unset, but env vars win:
AIRTABLE_BASE_ID=appTKXn43M25UPnYj
AIRTABLE_TABLE_ID=tblj8AafSljpchWoK

# --- Server-side: Bland.ai phone leads (Netlify Functions) ------------------
# /.netlify/functions/bland-call-lead receives Bland post-call webhooks and
# delivers each call as a phone lead to the SAME Slack + Airtable destinations
# above (it reuses SLACK_WEBHOOK_URL and the AIRTABLE_* vars — no new lead
# credentials needed). OPTIONAL shared secret: when BLAND_WEBHOOK_SECRET is set,
# requests must present it via the `x-bland-secret` header or a `?secret=` query
# param; leave it unset to disable verification during initial setup.
BLAND_WEBHOOK_SECRET=

# --- Server-side: AI assistant chat (Netlify Functions) ---------------------
# Powers /.netlify/functions/assistant-chat. OPTIONAL — when unset, the endpoint
# returns a grounded structured fallback built from Learning Center content, so
# the assistant page keeps working via the static guided answers. The key is
# server-only and never exposed to the client; it is not required for the build.
# Any OpenAI-compatible Chat Completions API works (set OPENAI_BASE_URL to point
# elsewhere). OPENAI_MODEL defaults to a low-cost model when unset.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Server-side: email notifications (Netlify Functions) -------------------
# Resend API key + the inbox that should receive new-lead notifications
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=
# Optional verified "from" address (defaults to Resend's onboarding sender)
LEAD_FROM_EMAIL=
