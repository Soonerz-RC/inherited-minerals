# ---------------------------------------------------------------------------
# Example environment variables. Copy to .env for local dev, and add the same
# keys in Netlify (Site settings → Environment variables) for production.
#
# Everything is optional. With no values set, tracking stays inert and form
# storage falls back to in-memory. Nothing here ships with real secrets.
# ---------------------------------------------------------------------------

# --- Client-side tracking (VITE_* are inlined at build time) ----------------
# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
VITE_GA4_MEASUREMENT_ID=
# Google Ads conversion account ID (AW-XXXXXXXXXX)
VITE_GOOGLE_ADS_ID=
# Google Ads conversion labels (the part after the slash in send_to)
VITE_GOOGLE_ADS_REVIEW_CONVERSION_LABEL=
VITE_GOOGLE_ADS_QUESTION_CONVERSION_LABEL=
# Meta (Facebook) Pixel ID
VITE_META_PIXEL_ID=
# Google Search Console verification token (the content of the meta tag)
VITE_GOOGLE_SITE_VERIFICATION=

# --- Phone / call tracking (VITE_*) -----------------------------------------
# Public business phone number shown in CTAs (e.g. +1 (555) 123-4567)
VITE_PUBLIC_PHONE_NUMBER=
# Optional call-tracking DID; when set, it is displayed/dialed instead
VITE_CALL_TRACKING_NUMBER=

# --- Lead capture backend (VITE_*) ------------------------------------------
# Where form submissions go. Leave unset (or "netlify-forms") to capture leads
# with Netlify Forms — the current default durable storage, viewable in the
# Netlify dashboard. Set to "api" later to POST to the Netlify Functions
# (Supabase/Neon) path instead.
#   netlify-forms (default) | api
VITE_LEAD_BACKEND=

# --- Server-side: durable storage, OPTIONAL / future (Netlify Functions) ----
# Only used when VITE_LEAD_BACKEND=api. Supabase project URL and SERVICE ROLE
# key (server-only — never expose client-side). Leave blank while on Netlify Forms.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Server-side: email notifications (Netlify Functions) -------------------
# Resend API key + the inbox that should receive new-lead notifications
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=
# Optional verified "from" address (defaults to Resend's onboarding sender)
LEAD_FROM_EMAIL=
